# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (confirmation email on signup)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=PolyLingo <noreply@polylingo.app>

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=polylingo.app

# Canonical URL (set after Vercel deploy, e.g. https://polylingo-lp.vercel.app)
NEXT_PUBLIC_SITE_URL=

# Optional: lock /learn to a single user (leave empty to allow anyone)
LEARN_ACCESS_CODE=
